{
  "manifest_version": 3,
  "name": "PSI Copy Feedback",
  "version": "1.0.0",
  "description": "One-click copying of PageSpeed Insights (Lighthouse) findings as AI-friendly plain text. Injects only on pagespeed.web.dev.",
  "minimum_chrome_version": "100",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://pagespeed.web.dev/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
